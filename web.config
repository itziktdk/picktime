<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <add name="iisnode" path="server-simple.js" verb="*" modules="iisnode"/>
    </handlers>
    <rewrite>
      <rules>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="server-simple.js"/>
        </rule>
      </rules>
    </rewrite>
    <iisnode nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;" />
  </system.webServer>
</configuration>